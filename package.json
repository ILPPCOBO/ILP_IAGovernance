{
  "name": "ai-governance-policy-builder",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Bilingual (EN/ES) preliminary AI governance policy builder for ordinary companies using generative AI.",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "PORT=8830 tsx watch src/server/index.ts",
    "dev:client": "vite",
    "build": "tsc --noEmit && vite build",
    "build:demo": "vite build --config vite.demo.config.ts",
    "build:single": "npm run build:demo && node scripts/build-singlefile.mjs",
    "preview": "vite preview",
    "start": "tsx src/server/index.ts",
    "samples": "tsx scripts/generate-samples.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "docx": "^8.5.0",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/supertest": "^6.0.2",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "supertest": "^7.0.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "vitest": "^2.0.5"
  }
}
